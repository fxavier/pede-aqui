        <mxCell id="title" value="Domain Events — Order Choreography (logical, in-process state changes)" style="text;html=1;fontSize=20;fontStyle=1;align=left;" vertex="1" parent="1">
          <mxGeometry x="60" y="20" width="900" height="30" as="geometry" />
        </mxCell>
        <mxCell id="note" value="No message bus — these are logical lifecycle events raised by service state transitions; consumers are called in-process (audit, notifications, settlement, ratings)." style="text;html=1;fontSize=12;align=left;fontColor=#666666;" vertex="1" parent="1">
          <mxGeometry x="60" y="52" width="1100" height="24" as="geometry" />
        </mxCell>

