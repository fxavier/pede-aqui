{
  "realm": "delivery",
  "enabled": true,
  "sslRequired": "none",
  "registrationAllowed": false,
  "roles": {
    "realm": [
      {
        "name": "ADMIN",
        "description": "Platform administrator"
      },
      {
        "name": "CUSTOMER",
        "description": "End customer"
      },
      {
        "name": "VENDOR_ADMIN",
        "description": "Vendor account admin"
      },
      {
        "name": "VENDOR_STAFF",
        "description": "Vendor staff member"
      },
      {
        "name": "COURIER",
        "description": "Delivery courier"
      },
      {
        "name": "FINANCE",
        "description": "Finance team"
      },
      {
        "name": "OPS",
        "description": "Operations team"
      },
      {
        "name": "SUPPORT",
        "description": "Support team"
      }
    ]
  },
  "userProfileConfig": {
    "attributes": [
      {
        "name": "username",
        "displayName": "${username}",
        "validations": { "length": { "min": 3, "max": 255 }, "username-prohibited-characters": {}, "up-username-not-idn-homograph": {} },
        "permissions": { "view": ["admin", "user"], "edit": ["admin", "user"] },
        "multivalued": false
      },
      {
        "name": "email",
        "displayName": "${email}",
        "validations": { "email": {}, "length": { "max": 255 } },
        "required": { "roles": ["user"] },
        "permissions": { "view": ["admin", "user"], "edit": ["admin", "user"] },
        "multivalued": false
      },
      {
        "name": "firstName",
        "displayName": "${firstName}",
        "validations": { "length": { "max": 255 }, "person-name-prohibited-characters": {} },
        "required": { "roles": ["user"] },
        "permissions": { "view": ["admin", "user"], "edit": ["admin", "user"] },
        "multivalued": false
      },
      {
        "name": "lastName",
        "displayName": "${lastName}",
        "validations": { "length": { "max": 255 }, "person-name-prohibited-characters": {} },
        "required": { "roles": ["user"] },
        "permissions": { "view": ["admin", "user"], "edit": ["admin", "user"] },
        "multivalued": false
      },
      {
        "name": "tenant_id",
        "displayName": "Tenant ID",
        "permissions": { "view": ["admin"], "edit": ["admin"] },
        "multivalued": false
      }
    ],
    "groups": [
      {
        "name": "user-metadata",
        "displayHeader": "User metadata",
        "displayDescription": "Attributes, which refer to user metadata"
      }
    ]
  },
  "clients": [
    {
      "clientId": "delivery-app",
      "name": "Delivery App",
      "enabled": true,
      "publicClient": true,
      "directAccessGrantsEnabled": true,
      "standardFlowEnabled": true,
      "redirectUris": [
        "http://localhost:3000/*",
        "http://localhost:3001/*"
      ],
      "webOrigins": [
        "+"
      ],
      "protocolMappers": [
        {
          "name": "tenant_id",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "consentRequired": false,
          "config": {
            "userinfo.token.claim": "true",
            "user.attribute": "tenant_id",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "claim.name": "tenant_id",
            "jsonType.label": "String"
          }
        }
      ]
    },
    {
      "clientId": "delivery-admin-service",
      "name": "Delivery Admin Service",
      "enabled": true,
      "publicClient": false,
      "secret": "${KEYCLOAK_ADMIN_CLIENT_SECRET:delivery-admin-secret}",
      "serviceAccountsEnabled": true,
      "directAccessGrantsEnabled": false,
      "standardFlowEnabled": false
    }
  ],
  "users": [
    {
      "username": "admin",
      "email": "admin@pede-aqui.com",
      "firstName": "Platform",
      "lastName": "Admin",
      "enabled": true,
      "credentials": [
        {
          "type": "password",
          "value": "admin123",
          "temporary": false
        }
      ],
      "realmRoles": [
        "ADMIN"
      ]
    },
    {
      "username": "finance",
      "email": "finance@pede-aqui.com",
      "firstName": "Finance",
      "lastName": "User",
      "enabled": true,
      "credentials": [
        {
          "type": "password",
          "value": "finance123",
          "temporary": false
        }
      ],
      "realmRoles": [
        "FINANCE"
      ]
    },
    {
      "username": "support",
      "email": "support@pede-aqui.com",
      "firstName": "Support",
      "lastName": "User",
      "enabled": true,
      "credentials": [
        {
          "type": "password",
          "value": "support123",
          "temporary": false
        }
      ],
      "realmRoles": [
        "SUPPORT"
      ]
    },
    {
      "username": "ops",
      "email": "ops@pede-aqui.com",
      "firstName": "Operations",
      "lastName": "User",
      "enabled": true,
      "credentials": [
        {
          "type": "password",
          "value": "ops123",
          "temporary": false
        }
      ],
      "realmRoles": [
        "OPS"
      ]
    }
  ]
}